{
	"name": "photopipe",
	"private": true,
	"version": "0.0.1",
	"description": "Self-hosted photo pipeline for camera shoots, denoising workflows, and image exports",
	"author": "Raphael Mitas",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/RaphaelMitas/photopipe.git"
	},
	"homepage": "https://github.com/RaphaelMitas/photopipe",
	"keywords": [
		"photography",
		"sveltekit",
		"pureraw",
		"denoising",
		"photo-management",
		"sharp"
	],
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --check .",
		"format:fix": "prettier --write .",
		"lint": "eslint .",
		"lint:fix": "eslint --fix .",
		"typecheck": "pnpm check",
		"audit": "pnpm audit --audit-level high",
		"clean": "git clean -xdf node_modules .svelte-kit build"
	},
	"dependencies": {
		"@sveltejs/adapter-node": "^5.5.4",
		"archiver": "^7.0.1",
		"convex": "^1.35.1",
		"convex-svelte": "^0.0.12",
		"sharp": "^0.34.5",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/archiver": "^7.0.0",
		"@types/node": "^24.12.2",
		"eslint": "^10.2.1",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.5.0",
		"jiti": "^2.6.1",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.4",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.2",
		"vite": "^8.0.8"
	},
	"packageManager": "pnpm@11.0.0-rc.1+sha512.0d7d837668eb35b81d28f560ef8ec5e103ff5d162e249fd0d30c546c39a551d290ac9cf15709353b94d2df6eb445bfa465c7a05148d328eda32950c02e40d060"
}

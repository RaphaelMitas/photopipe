{
	"name": "photopipe",
	"private": true,
	"version": "0.0.1",
	"description": "Self-hosted photo pipeline for camera shoots, denoising workflows, and image exports",
	"author": "Raphael Mitas",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/RaphaelMitas/photopipe.git"
	},
	"homepage": "https://github.com/RaphaelMitas/photopipe",
	"keywords": [
		"photography",
		"sveltekit",
		"pureraw",
		"denoising",
		"photo-management",
		"sharp"
	],
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --check .",
		"format:fix": "prettier --write .",
		"lint": "eslint .",
		"lint:fix": "eslint --fix .",
		"typecheck": "pnpm check",
		"audit": "pnpm audit --audit-level high",
		"clean": "git clean -xdf node_modules .svelte-kit build"
	},
	"dependencies": {
		"@sveltejs/adapter-node": "^5.5.4",
		"archiver": "^7.0.1",
		"convex": "^1.38.0",
		"convex-svelte": "^0.0.12",
		"sharp": "^0.34.5",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/kit": "^2.59.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/archiver": "^7.0.0",
		"@types/node": "^24.12.3",
		"eslint": "^10.3.0",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"jiti": "^2.7.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.2",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.8",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.2",
		"vite": "^8.0.12"
	},
	"packageManager": "pnpm@11.0.9+sha512.34ce82e6780233cf9cad8685029a8f81d2e06196c5a9bad98879f7424940c6817c4e4524fb7d38b8553ceed48b9758b8ebaf1abd3600c232c4c8cf7366086f38"
}

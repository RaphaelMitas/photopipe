{
	"name": "photopipe",
	"private": true,
	"version": "0.0.1",
	"description": "Self-hosted photo pipeline for camera shoots, denoising workflows, and image exports",
	"author": "Raphael Mitas",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/RaphaelMitas/photopipe.git"
	},
	"homepage": "https://github.com/RaphaelMitas/photopipe",
	"keywords": [
		"photography",
		"sveltekit",
		"pureraw",
		"denoising",
		"photo-management",
		"sharp"
	],
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --check .",
		"format:fix": "prettier --write .",
		"lint": "eslint .",
		"lint:fix": "eslint --fix .",
		"typecheck": "pnpm check",
		"audit": "pnpm audit --audit-level high",
		"clean": "git clean -xdf node_modules .svelte-kit build"
	},
	"dependencies": {
		"@sveltejs/adapter-node": "^5.5.4",
		"archiver": "^7.0.1",
		"convex": "^1.37.0",
		"convex-svelte": "^0.0.12",
		"sharp": "^0.34.5",
		"zod": "^4.4.1"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/kit": "^2.58.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/archiver": "^7.0.0",
		"@types/node": "^24.12.2",
		"eslint": "^10.2.1",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.5.0",
		"jiti": "^2.6.1",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.1",
		"vite": "^8.0.10"
	},
	"packageManager": "pnpm@11.0.2+sha512.6926cf7cd7812b2800e3a210551b5ec845f77ebeba816424a95014de3021d193b3b55c5b4b74bac4eba106979e798aa0505646181ce67247507312532a661787"
}
